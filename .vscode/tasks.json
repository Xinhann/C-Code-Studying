{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-c",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall",
        "-mconsole",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
